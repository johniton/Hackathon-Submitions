# ─── SkillMap Job Scraper — Environment Variables ────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Service ──────────────────────────────────────────────────────────────────
PORT=8001
DEBUG=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=1800
REDIS_DEDUP_TTL=86400

# ── LinkedIn (optional — needed only for package-based scraping) ───────────────
# If left empty, the service falls back to Playwright public scraping.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Proxy (optional) ──────────────────────────────────────────────────────────
# Format: http://username:password@host:port
# Leave empty to disable proxy routing.
PROXY_URL=

# ── Scraper tuning ────────────────────────────────────────────────────────────
RATE_LIMIT_DELAY_MIN=1.5
RATE_LIMIT_DELAY_MAX=4.0
MAX_RETRIES=3
REQUEST_TIMEOUT=30
PLAYWRIGHT_TIMEOUT=45000
